{
  "name": "Wizard Drumkit",
  "description": "Euclidean drum sequencer with 3 voices (kick, snare, hihat) and chaos/swing",
  "knobs": {
    "1": "BPM (20–300, overridden by external clock)",
    "2": "Kick Euclidean fill density",
    "3": "HiHat Perlin noise density threshold",
    "4": "Snare Perlin noise density threshold",
    "5": "Chaos / swing amount",
    "6": "Kick pattern length (1–32 steps)"
  },
  "cv_in": {
    "1": "HiHat stereo pan (±1V = left/right)",
    "2": "Snare frequency modulation (+100 Hz per 1V)"
  },
  "gate_in": {
    "1": "External clock (overrides internal BPM)",
    "2": "Open hihat trigger (long decay)"
  },
  "gate_out": {
    "1": "Clock pulse (every step)",
    "2": "Kick trigger pulse"
  },
  "cv_out": {
    "1": "HiHat noise value (0–5V)",
    "2": "Logistic chaos value (0–5V)"
  },
  "leds": "16-step sequencer position (2 steps per LED, bright = active)",
  "audio_in": "Mixed with drum synthesis output",
  "audio_out": "Stereo kick + snare + panned hihat mix"
}
